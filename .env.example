# LLM Configuration（统一四元配置）
# ASTRACORE__LLM__PROVIDER: deepseek | anthropic
ASTRACORE__LLM__PROVIDER=deepseek
ASTRACORE__LLM__BASE_URL=https://api.deepseek.com
ASTRACORE__LLM__API_KEY=
ASTRACORE__LLM__MODEL=deepseek-chat
# ASTRACORE__LLM__MAX_TOKENS=8192  # 模型单次回复最大 token 数，默认 8192

# Agent / Tool-loop Configuration
# ASTRACORE__AGENT__MAX_TOOL_RESULT_CHARS=20000  # 单条工具结果最大字符数，超出自动截断，默认 20000
# ASTRACORE__AGENT__MAX_TOOL_ITERATIONS=10       # 工具循环最大轮次，默认 10

# Memory Configuration
ASTRACORE__MEMORY__REDIS_URL=redis://localhost:6379/0
ASTRACORE__MEMORY__DB_URL=sqlite+aiosqlite:///./astracore.db

# Retrieval Configuration
ASTRACORE__RETRIEVAL__COLLECTION_NAME=astracore
ASTRACORE__RETRIEVAL__PERSIST_DIRECTORY=./chroma_db

# ──────────────────────────────────────────────────────────────
# Docker 部署说明
# ──────────────────────────────────────────────────────────────
# 1. 复制本文件: cp .env.example .env
# 2. 填入 ASTRACORE__LLM__API_KEY
# 3. 启动: docker-compose up -d
# 4. 访问: http://localhost:8000
#
# 注意: Docker 运行时以下三项会被 docker-compose.yml 自动覆盖，
#       无需手动修改：
#   ASTRACORE__MEMORY__REDIS_URL  → redis://redis:6379/0
#   ASTRACORE__MEMORY__DB_URL     → sqlite+aiosqlite:////app/data/astracore.db
#   ASTRACORE__RETRIEVAL__PERSIST_DIRECTORY → /app/data/chroma_db

# Tavily（联网搜索，可选）
# 免费注册：https://tavily.com
# TAVILY_API_KEY=tvly-xxx

# MCP Servers（可选，JSON 数组，留空则不启用）
# 允许 AI Agent 通过 MCP 协议访问本地文件系统和执行受控 shell 命令
# 前提：Node.js 已安装；首次运行会自动下载 @modelcontextprotocol/server-filesystem
#
# 三种 type：
#   filesystem  — @modelcontextprotocol/server-filesystem，paths 为允许访问的目录列表
#   shell       — 内置 shell server，allow_dirs 为允许执行命令的目录，timeout 单位秒（默认 30）
#   custom      — 自定义外部进程，需手动填写 command/args/env
#
# 仅 filesystem：
# ASTRACORE__MCP__SERVERS='[{"type":"filesystem","paths":["D:/project"]}]'
#
# filesystem + shell：
# ASTRACORE__MCP__SERVERS='[{"type":"filesystem","paths":["D:/project"]},{"type":"shell","allow_dirs":["D:/project"]}]'
#
# 自定义外部 server：
# ASTRACORE__MCP__SERVERS='[{"type":"custom","name":"my-server","command":"npx","args":["-y","some-mcp-package"]}]'
