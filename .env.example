# AstraCoreAI 结构化配置在 config/config.yaml 中维护。
# .env 只放密钥和少量环境差异配置。

# 配置文件路径（可选，默认读取 ./config/config.yaml）
# ASTRACORE_CONFIG=config/config.yaml

# LLM API Keys（与 config/config.yaml 里的 api_key_env 对应）
# ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_PROXY_API_KEY=app-key-xxx
# DEEPSEEK_API_KEY=sk-xxx

# ──────────────────────────────────────────────────────────────
# Docker 部署说明
# ──────────────────────────────────────────────────────────────
# 1. 复制本文件: cp .env.example .env
# 2. 复制 config/config.example.yaml 为 config/config.yaml，并按需调整模型、MCP、数据库等结构化配置
# 3. 填入 config/config.yaml 中 api_key_env 对应的密钥
# 4. 启动: docker-compose up -d
# 5. 访问: http://localhost:8000
#
# 注意: Docker 内的路径、Redis 地址等请在 config/config.docker.yaml 中维护。

# Tavily（联网搜索，可选，与联网工具对应）
# 免费注册：https://tavily.com
# TAVILY_API_KEY=tvly-xxx
