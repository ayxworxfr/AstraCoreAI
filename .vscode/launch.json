{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "AstraCore: Debug API",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/examples/run_service.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "AstraCore: Pytest current file",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "--color=yes",
                "-v",
                "-s",
                "${file}"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "PYTEST_ASYNCIO_MODE": "auto"
            }
        },
        {
            "name": "AstraCore: Pytest selected tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "--color=yes",
                "-v",
                "-s",
                "${file}",
                "-k",
                "${selectedText}"
            ],
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src",
                "PYTEST_ASYNCIO_MODE": "auto"
            }
        }
    ]
}
